# Services / backend (NON-PROD/dev). Matches docker/docker-compose.local.yml. NEVER commit real secrets.
NODE_ENV=development
PORT=3333
# Postgres (local docker)
DATABASE_URL=postgres://app:app@localhost:5432/appdb
# Redis (local docker)
REDIS_URL=redis://localhost:6379
# Auth (dev)
JWT_SECRET=dev-only-change-me
# 3rd-party sandbox keys (leave blank → feature off / mock)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
OPENAI_API_KEY=
