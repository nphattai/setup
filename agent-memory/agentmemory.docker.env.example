# Template for agentmemory.docker.env (the live file is gitignored).
# Copy to agentmemory.docker.env and tune. No real secrets belong here — the proxy
# ignores the API key (it auths via your mounted Antigravity creds), but the
# agentmemory/OpenAI client requires a non-empty value.
#   cp agentmemory.docker.env.example agentmemory.docker.env

# LLM provider = host CLIProxyAPI (Antigravity OAuth) at host.docker.internal:8317.
# OPENAI_API_KEY is unused by the proxy but must be non-empty — any dummy works.
OPENAI_API_KEY=sk-dummy-unused-by-proxy
OPENAI_BASE_URL=http://host.docker.internal:8317
OPENAI_MODEL=gemini-3-flash

# Local embeddings (384-dim MiniLM, downloaded once). The proxy does not serve
# /v1/embeddings, so embeddings MUST be local.
EMBEDDING_PROVIDER=local

# Feature flags (see agentmemory docs).
AGENTMEMORY_AUTO_COMPRESS=true      # LLM-compress every observation (uses the proxy)
AGENTMEMORY_INJECT_CONTEXT=true     # inject recalled memories back into agent prompts
CONSOLIDATION_ENABLED=true          # 4-tier memory consolidation pipeline
CONSOLIDATION_DECAY_DAYS=7
GRAPH_EXTRACTION_ENABLED=true       # concept-graph edges for graph recall
AGENTMEMORY_REFLECT=true            # periodic lesson synthesis
AGENTMEMORY_TOOLS=all               # MCP tool surface: all (51) | core (7)

# Timeouts.
AGENTMEMORY_LLM_TIMEOUT_MS=180000
OPENAI_TIMEOUT_MS=180000

# Embedding model cache (persisted via the agentmemory_cache volume).
HF_HOME=/root/.cache/huggingface
TRANSFORMERS_CACHE=/root/.cache/huggingface
XDG_CACHE_HOME=/root/.cache

# Idempotent safety guard: discard a persisted vector index whose dimension no
# longer matches the active embedder (otherwise the engine refuses to start and
# crash-loops). Harmless on a fresh install and with a fixed local/384 provider —
# safe to leave ON.
AGENTMEMORY_DROP_STALE_INDEX=true
