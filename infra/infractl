#!/usr/bin/env bash
# infractl — manage the shared local dev infra (one Postgres + one Redis).
#
# Model: a single always-on stack. Isolation is LOGICAL:
#   - PG : a dedicated database per project key   (enforced by Postgres)
#   - Redis: a key prefix per project key         (app MUST apply via ioredis keyPrefix)
# Per-project grain (v1): worktrees of the same project SHARE the project DB, so backend
# tasks stay serialized (multica DECISIONS #12/#16). Flip to per-worktree keys later for
# parallel backend at zero container cost.
#
# Usage:
#   infractl up                       start the shared stack (idempotent, waits healthy)
#   infractl down                     stop the stack (keeps data volumes)
#   infractl wipe                     stop AND destroy data volumes (asks to confirm)
#   infractl status                   show containers + databases + derived prefixes
#   infractl db-create <key>          CREATE DATABASE for a project key (idempotent)
#   infractl env <key> [--write DIR]  print (or write DIR/.env.infra) connection vars
#   infractl psql <key>               open psql against the project's database
#
# <key> = project name, e.g. infina-insurance-partner-services
set -euo pipefail

INFRA_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMPOSE_FILE="$INFRA_DIR/compose/infra.yml"
PROJECT="dev-infra"            # matches `name:` in compose/infra.yml

PG_PORT=5432
REDIS_PORT=6379
PG_USER=dev
PG_PASS=dev

dc()      { docker compose -f "$COMPOSE_FILE" "$@"; }
pg_exec() { docker compose -f "$COMPOSE_FILE" exec -T postgres "$@"; }
die()     { echo "infractl: $*" >&2; exit 1; }

# Derive a valid PG identifier + Redis prefix from a project key (deterministic, no state).
#   infina-insurance-partner-services -> db: infina_insurance_partner_services
#                                        prefix: infina-insurance-partner-services:
db_name() { echo "$1" | tr '[:upper:]-' '[:lower:]_' | tr -cd '[:alnum:]_'; }

require_running() {
  dc ps --status running --services 2>/dev/null | grep -q postgres \
    || die "stack not running — 'infractl up' first"
}

cmd_up() {
  dc up -d
  echo -n "infractl: waiting for postgres "
  for _ in $(seq 1 30); do
    if pg_exec pg_isready -U "$PG_USER" >/dev/null 2>&1; then echo "ok"; break; fi
    echo -n "."; sleep 1
  done
  echo "infractl: up — PG 127.0.0.1:$PG_PORT · Redis 127.0.0.1:$REDIS_PORT"
}

cmd_down() { dc down; echo "infractl: stopped (data kept)"; }

cmd_wipe() {
  read -r -p "infractl: DESTROY all shared dev data (PG + Redis volumes)? [y/N] " a
  [ "$a" = "y" ] || { echo "aborted"; exit 0; }
  dc down -v
  echo "infractl: wiped"
}

cmd_status() {
  dc ps
  if dc ps --status running --services 2>/dev/null | grep -q postgres; then
    echo; echo "databases (project keys):"
    pg_exec psql -U "$PG_USER" -d postgres -tAc \
      "SELECT datname FROM pg_database WHERE datname NOT IN ('postgres','template0','template1') ORDER BY 1;" \
      | sed 's/^/  - /'
    echo "redis: one shared keyspace; each app namespaces its own keys (e.g. insurtech 'ins_')"
  fi
}

cmd_db_create() {
  local key="${1:?usage: infractl db-create <key>}"; require_running
  local db; db="$(db_name "$key")"
  # idempotent CREATE DATABASE (no IF NOT EXISTS in PG DDL — guard with a check)
  if pg_exec psql -U "$PG_USER" -d postgres -tAc \
       "SELECT 1 FROM pg_database WHERE datname='$db';" | grep -q 1; then
    echo "infractl: database '$db' already exists"
  else
    pg_exec psql -U "$PG_USER" -d postgres -c "CREATE DATABASE \"$db\";"
    echo "infractl: created database '$db'"
  fi
}

cmd_env() {
  local key="${1:?usage: infractl env <key> [--write DIR]}"; shift || true
  local db
  db="$(db_name "$key")"
  local body
  body="$(cat <<EOF
# Generated by infractl for project key: $key
# Copy into the app's .env.local (or source it) so it talks to the shared dev infra.
# Discrete DB_* vars = what @infinavn/common PGConfig reads. DATABASE_URL = Makefile
# dump/restore + typeorm CLI. Redis isolation is the APP's job (it sets its own ioredis
# keyPrefix, e.g. insurtech-service uses 'ins_'); infra just provides one Redis.
DB_HOST=127.0.0.1
DB_PORT=$PG_PORT
DB_NAME=$db
DB_USERNAME=$PG_USER
DB_PASSWORD=$PG_PASS
DATABASE_URL=postgresql://$PG_USER:$PG_PASS@127.0.0.1:$PG_PORT/$db
REDIS_URL=redis://127.0.0.1:$REDIS_PORT
EOF
)"
  if [ "${1:-}" = "--write" ]; then
    local dir="${2:?--write needs a DIR}"
    printf '%s\n' "$body" > "$dir/.env.infra"
    echo "infractl: wrote $dir/.env.infra"
  else
    printf '%s\n' "$body"
  fi
}

cmd_psql() {
  local key="${1:?usage: infractl psql <key>}"; require_running
  pg_exec psql -U "$PG_USER" -d "$(db_name "$key")"
}

case "${1:-}" in
  up)         shift; cmd_up "$@";;
  down)       shift; cmd_down "$@";;
  wipe)       shift; cmd_wipe "$@";;
  status|ps)  shift; cmd_status "$@";;
  db-create)  shift; cmd_db_create "$@";;
  env)        shift; cmd_env "$@";;
  psql)       shift; cmd_psql "$@";;
  *) grep '^#' "${BASH_SOURCE[0]}" | sed -n '2,30p' | sed 's/^# \{0,1\}//'; exit 1;;
esac
